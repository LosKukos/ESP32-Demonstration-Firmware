// --- Knihovny ---
#include <controls.h>

Controls controls;
auto& display = controls.display;

// --- PPG proměnné ---
int ambientBaseline = 0;
int currentValue = 0;
const unsigned long ppgReadInterval = 20;
unsigned long lastPPGReadTime = 0;

// --- FIFO buffer ---
const int bufferSize = 128;
int ppgBuffer[bufferSize];
int bufferIndex = 0;

// --- Filtrace PPG ---
float emaValue = 0;
const float alpha = 0.2;
int smaBuffer[5] = {0};
int smaIndex = 0;

// --- BPM výpočet ---
unsigned long lastPeakTime = 0;
int currentBPM = 0;
bool bpmIsValid = false;

// --- Menu stav ---
bool menuActive = false;
int menuSelection = 0;
const char* menuItems[] = { "Kalibrace", "Autozoom", "Zpet", "Konec" };
const int menuItemCount = 4;

// --- LED mód ---
enum LedMode { IR, RED };
LedMode currentMode = IR;

enum SystemState { MEASURING, MENU, CALIBRATION };
SystemState currentState = MEASURING;

// --- Thresholdy ---
int adjThreshold;
const int minBeatInterval = 300;
int touch_baseline = 20;

// --- Display ---
const int bpmX = 0;
const int bpmY = 0;
bool autoZoomEnabled = false;

// --- BPM buffer ---
const int intervalBufferSize = 4;
unsigned long intervalBuffer[intervalBufferSize] = {0};
int intervalIndex = 0;

// --- Globální proměnné ---
const unsigned long fingerHoldTime = 250;
unsigned long lastPeakTime_LED = 0;
const unsigned long blinkDuration = 50; // ms
bool ledOn = false;
bool peakFlag = false;


void setup() {
    Serial.begin(115200);

    controls.begin();

    display.clearDisplay();
    display.display();

    // --- LED ---
    controls.strip.begin();
    controls.strip.show(); // zhasnutí všech LED

    // --- Kalibrace touch ---
    calibrateTouch();

    // --- Kalibrace PPG ---
    calibrateSensor();
}

void loop() {
    blinkPeak(peakFlag);  // LED indikace peaku

    switch(currentState) {
        case MEASURING:
            sampleAndProcessPPG(); // čtení a zpracování PPG
            handleLedSwitch();     // přepínání LED
            handleStateSwitch();   // tlačítka → menu
            break;

        case MENU:
            handleStateSwitch();   // menu navigace / potvrzení
            break;

        case CALIBRATION:
            calibrateSensor();
            currentState = MEASURING; // zpět do měření
            break;
    }
}

void sampleAndProcessPPG() {
    if (millis() - lastPPGReadTime < ppgReadInterval) return;
    lastPPGReadTime = millis();

    bool fingerOn = fingerTouched(); // jediná funkce pro detekci prstu
    display.clearDisplay();

    if (fingerOn) {
        int rawValue = ReadPPG();

        // EMA filtr
        emaValue = alpha * rawValue + (1 - alpha) * emaValue;

        // SMA buffer
        smaBuffer[smaIndex] = (int)emaValue;
        smaIndex = (smaIndex + 1) % 5;

        int smaSum = 0;
        for (int i = 0; i < 5; i++) smaSum += smaBuffer[i];
        currentValue = smaSum / 5;

        // FIFO buffer
        ppgBuffer[bufferIndex] = currentValue;
        bufferIndex = (bufferIndex + 1) % bufferSize;

        // Dynamický threshold
        adjThreshold = calculateDynamicThreshold(ppgBuffer, bufferSize, bufferIndex);

        // Peak detection
        peakFlag = detectPeak(currentValue, adjThreshold);
        if (peakFlag) Serial.println("Peak");

        // Kreslení PPG
        drawPPGCurve(ppgBuffer, bufferIndex, bufferSize, SCREEN_WIDTH, SCREEN_HEIGHT, currentMode);

    } else {
        display.setTextSize(1);
        display.setTextColor(SH110X_WHITE);
        display.setCursor(25, SCREEN_HEIGHT / 2 - 3);
        display.println("Prilozte prst");
    }

    // BPM zobrazení
    displayBPM();
    display.display();
}

void handleStateSwitch() {
    // --- Otevření menu z MEASURING ---
    if (currentState == MEASURING && controls.EncoderRight || controls.rightPressed) {
        controls.EncoderRight = false;
        controls.rightPressed = false;
        currentState = MENU;
        menuSelection = 0;
        menuActive = true;
        drawMenu();
    }

    // --- Menu není aktivní → nic nedělej ---
    if (currentState != MENU || !menuActive) return;

    // --- Navigace v menu ---
    if (controls.EncoderLeft || controls.leftPressed) {
        menuSelection = (menuSelection - 1 + menuItemCount) % menuItemCount;
        drawMenu();
        controls.EncoderLeft = false;
        controls.leftPressed = false;
    }

    if (controls.EncoderRight || controls.rightPressed) {
        menuSelection = (menuSelection + 1) % menuItemCount;
        drawMenu();
        controls.EncoderRight = false;
        controls.rightPressed = false;
    }

    // --- Potvrzení volby touch senzorem ---
    if (fingerMenuPressed()) {
    const char* item = menuItems[menuSelection];

    if (strcmp(item, "Kalibrace") == 0) {
        currentState = CALIBRATION;
        menuActive = false;
    }
    else if (strcmp(item, "Autozoom") == 0) {
        autoZoomEnabled = !autoZoomEnabled;
        drawMenu();
    }
    else if (strcmp(item, "Zpet") == 0) {
        currentState = MEASURING;
        menuActive = false;
        display.clearDisplay();
    }
    else if (strcmp(item, "Konec") == 0) {
        // případně ukončení programu / reset
    }
}
}

void handleLedSwitch() {
    static bool prevButtonState = HIGH;

    // přečteme stav tlačítka z Controls
    bool buttonState = controls.leftPressed;

    // detekce přepnutí (falling edge)
    if (prevButtonState == HIGH && buttonState == LOW) {
        // přepnutí módu
        currentMode = (currentMode == IR) ? RED : IR;

        Serial.print("Přepnuto na ");
        Serial.println(currentMode == IR ? "IR" : "RED");
    }

    // uložíme stav pro příště
    prevButtonState = buttonState;

    // reset tlačítka v Controls
    controls.leftPressed = false;

    // aktualizace LED podle aktuálního módu
    digitalWrite(controls.IR_LED_PIN, currentMode == IR ? HIGH : LOW);
    digitalWrite(controls.RED_LED_PIN, currentMode == RED ? HIGH : LOW);
}

bool detectPeak(int currentValue, int threshold) {
    // statické proměnné si pamatují stav mezi voláními
    static int prevValue = 0;
    static unsigned long lastPeakMillis = 0;

    bool peakDetected = false;

    // Detekce peak: hodnota klesá po překročení threshold
    if (prevValue > threshold && currentValue < prevValue) {
        unsigned long now = millis();
        unsigned long interval = now - lastPeakMillis;

        // respektujeme minimální interval mezi tepy
        if (interval >= minBeatInterval) {
            peakDetected = true;
            calculateBPM(interval);
            lastPeakMillis = now;
        }
    }

    prevValue = currentValue;
    return peakDetected;
}

void calculateBPM(unsigned long interval) {
    // Uloží aktuální interval do kruhového bufferu
    intervalBuffer[intervalIndex] = interval;
    intervalIndex = (intervalIndex + 1) % intervalBufferSize;

    // Spočítáme průměr intervalů (ne nula)
    unsigned long sum = 0;
    int validCount = 0;

    for (int i = 0; i < intervalBufferSize; i++) {
        if (intervalBuffer[i] > 0) {
            sum += intervalBuffer[i];
            validCount++;
        }
    }

    if (validCount == 0) {
        bpmIsValid = false;
        return;
    }

    unsigned long avgInterval = sum / validCount;
    int bpm = 60000 / avgInterval;

    // omezení na realistické BPM
    bpmIsValid = (bpm >= 40 && bpm <= 180);
    if (bpmIsValid) currentBPM = bpm;
}

void calibrateSensor() {
    // Vypneme LED
    digitalWrite(controls.IR_LED_PIN, LOW);
    digitalWrite(controls.RED_LED_PIN, LOW);
    delay(500);

    const int totalSamples = 100;
    long sum = 0;

    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SH110X_WHITE);
    display.setCursor(0, 0);
    display.println("Kalibrace senzoru...");
    display.display();

    for (int i = 0; i < totalSamples; i++) {
        sum += analogRead(controls.PPG_PIN);

        // progress bar 0–100
        int progressWidth = map(i, 0, totalSamples - 1, 0, 100);
        display.fillRect(0, 20, progressWidth, 10, SH110X_WHITE);
        display.display();

        delay(10);
    }

    ambientBaseline = sum / totalSamples;

    display.clearDisplay();
    display.setCursor(0, 0);
    display.println("Kalibrace dokoncena!");
    display.display();

    Serial.print("Novy baseline: ");
    Serial.println(ambientBaseline);

    delay(1000);
}

int ReadPPG() {
  return analogRead(controls.PPG_PIN) - ambientBaseline;
}

void drawPPGCurve(int* buffer, int index, int size, int width, int height, LedMode mode) {
    // --- Základní rozložení ---
    int topMargin = 10;
    int bottomMargin = 5;
    int availableHeight = height - topMargin - bottomMargin;
    int axisY = topMargin + availableHeight / 2; // baseline uprostřed
    long sum_auto = 0;
    const float manual_baseline = 10;

    // --- Manuální nastavení ---
    const float manualZoomFactor = 2.0;
    const int manualAmplitude = 5000;

    // --- Zoom určení ---
    float zoom;
    float ppgBaseline;
    if (autoZoomEnabled) {
        // --- AUTO režim ---
        int minVal = buffer[0], maxVal = buffer[0];
        long sum_auto = 0;
        const int windowSize = min(size, 80);

    for (int i = 0; i < windowSize; i++) {
        int idx = (index - i + size) % size;
        int val = buffer[idx];
        if (val > maxVal) maxVal = val;
        if (val < minVal) minVal = val;
        sum_auto += val;
    }

    ppgBaseline = (float)sum_auto / windowSize;  // dynamická baseline pro autozoom
    int dynamicAmplitude = maxVal - minVal;
    if (dynamicAmplitude == 0) dynamicAmplitude = 1;

    Serial.print("ppgbaseline auto:");
    Serial.println(ppgBaseline);
    Serial.print("dyn_amp:");
    Serial.println(dynamicAmplitude);

    zoom = (float)availableHeight / dynamicAmplitude;

    }else {
        // --- MANUAL režim ---
        ppgBaseline = manual_baseline;  // fixní baseline
        zoom = manualZoomFactor * ((float)availableHeight / manualAmplitude);
    }

    // --- Kreslení křivky ---
    float xStep = (float)width / (size - 1);
    for (int i = 1; i < size; i++) {
        int currentIndex = (index + i) % size;
        int prevIndex = (index + i - 1) % size;

        int y1 = axisY - (buffer[prevIndex] - ppgBaseline) * zoom;
        int y2 = axisY - (buffer[currentIndex] - ppgBaseline) * zoom;

        y1 = constrain(y1, topMargin, height - bottomMargin - 1);
        y2 = constrain(y2, topMargin, height - bottomMargin - 1);

        display.drawLine((i - 1) * xStep, y1, i * xStep, y2, SH110X_WHITE);
    }
}

void displayBPM() {
    display.setTextSize(1);
    display.setTextColor(SH110X_WHITE);

    display.setCursor(bpmX, bpmY);
    display.print("BPM:");
    display.setCursor(bpmX + 25, bpmY);
    if (bpmIsValid) {
     display.print(currentBPM);
    } else {
     display.print("...");
    }

    display.setCursor(bpmX + 100, bpmY);
    display.print(currentMode == IR ? "IR" : "RED");
}

int calculateDynamicThreshold(const int* buffer, int size, int index) {
    const int window = 16;  // sliding window
    static float smoothed = 0;

    int maxVal = buffer[index];
    int minVal = buffer[index];

    // najdi min a max v okně
    for (int i = 0; i < window; i++) {
        int idx = (index - i + size) % size;
        maxVal = max(maxVal, buffer[idx]);
        minVal = min(minVal, buffer[idx]);
    }

    int newThreshold = minVal + (maxVal - minVal) * 0.6f;

    // EMA pro hladší adaptaci
    smoothed = alpha * newThreshold + (1 - alpha) * smoothed;

    return (int)smoothed;
}

void drawMenu() {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SH110X_WHITE);
    display.setCursor(0, 0);
    display.println("==== NASTAVENI ====");

    for (int i = 0; i < menuItemCount; i++) {
        display.setCursor(0, i * 10 + 10);
        display.print((i == menuSelection) ? "> " : "  ");
        display.print(menuItems[i]);

        // ON/OFF vedle Autozoom
        if (strcmp(menuItems[i], "Autozoom") == 0) {
            display.setCursor(90, i * 10 + 10);
            display.print(autoZoomEnabled ? "ON" : "OFF");
        }
    }

    display.display();
}

void blinkPeak(bool peak) {
    unsigned long now = millis();

    if (peak) {
        controls.strip.setPixelColor(0, 0, 255, 0); // modrá
        controls.strip.show();
        lastPeakTime_LED = now;
        ledOn = true;
        return; // pokud je peak, hned blikni a skonči
    }

    // zhasnutí po blinkDuration
    if (ledOn && now - lastPeakTime_LED >= blinkDuration) {
        controls.strip.setPixelColor(0, 0, 0, 0); // zhasni
        controls.strip.show();
        ledOn = false;
    }
}

void calibrateTouch() {
    long sum = 0;
    const int samples = 20;

    for (int i = 0; i < samples; i++) {
        sum += touchRead(controls.TOUCH_PIN);
        delay(10);
    }

    touch_baseline = sum / samples;
}

bool fingerTouched() {
    static bool state = false;
    static unsigned long lastChangeTime = 0;

    int t = touchRead(controls.TOUCH_PIN);
    int threshold = max(5, touch_baseline - 10);

    bool currentlyTouched = t < threshold;

    if (currentlyTouched != state) {
        if (lastChangeTime == 0) lastChangeTime = millis();
        if (millis() - lastChangeTime >= fingerHoldTime) {
            state = currentlyTouched;
            lastChangeTime = 0;
        }
    } else {
        lastChangeTime = 0;
    }

    return state;
}

bool fingerMenuPressed() {
    static bool prevMenuState = false;
    bool currentMenuState = fingerTouched(); // drží prst při měření
    bool pressed = (!prevMenuState && currentMenuState); // pouze první přiložení
    prevMenuState = currentMenuState;
    return pressed;
}
