{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ESP32 Serial Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/<nazwa_tvojho_firmware>.elf",
            "miDebuggerPath": "xtensa-esp32-elf-gdb",
            "miDebuggerServerAddress": "localhost:3333",
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "serialPort": "COM3",
            "baudRate": 115200
        }
    ]
}